// CD (Windows): pull образа -> docker compose up (api+db) -> seed -> сценарии.
// Creds: dockerhub-creds, pg-creds (usernamePassword: POSTGRES_USER / POSTGRES_PASSWORD).
// Global ENV: DOCKERHUB_USER.

pipeline {
    agent any

    options {
        timestamps()
    }

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Тег образа на Docker Hub')
    }

    environment {
        DOCKERHUB_USER = "${env.DOCKERHUB_USER ?: 'YOUR_DOCKERHUB_LOGIN'}"
        IMAGE = "${DOCKERHUB_USER}/devops2-api"
        SCENARIO_BASE_URL = "http://127.0.0.1:8000"
    }

    stages {
        stage('checkout_repo') {
            steps {
                checkout scm
            }
        }

        stage('docker_login_pull') {
            steps {
                bat 'docker --version'
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'DH_USER',
                        passwordVariable: 'DH_PASS'
                    )
                ]) {
                    bat 'echo %DH_PASS% | docker login -u %DH_USER% --password-stdin'
                }
                bat "docker pull ${IMAGE}:${params.IMAGE_TAG}"
                bat "docker tag ${IMAGE}:${params.IMAGE_TAG} devops2-api:latest"
            }
        }

        stage('compose_up') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'pg-creds',
                        usernameVariable: 'POSTGRES_USER',
                        passwordVariable: 'POSTGRES_PASSWORD'
                    )
                ]) {
                    bat '''
                        (echo POSTGRES_DB=devops& echo POSTGRES_USER=%POSTGRES_USER%& echo POSTGRES_PASSWORD=%POSTGRES_PASSWORD%) > .env
                        docker compose down -v
                        docker compose up -d
                    '''
                    bat 'ping -n 26 127.0.0.1 > nul'
                }
            }
        }

        stage('seed_db') {
            steps {
                script {
                    def rc = bat(returnStatus: true, script: 'docker compose exec -T api python scripts/seed_db.py')
                    if (rc != 0) {
                        echo "seed_db skipped (rc=${rc}) -- data/raw/data.csv нет в образе либо не подтянут DVC"
                    }
                }
            }
        }

        stage('functional_scenarios') {
            steps {
                bat 'set SCENARIO_BASE_URL=http://127.0.0.1:8000 && python scripts/run_scenarios.py'
            }
        }
    }

    post {
        always {
            bat(returnStatus: true, script: 'docker compose logs --no-color > compose-logs.txt 2>&1')
            archiveArtifacts artifacts: 'compose-logs.txt', allowEmptyArchive: true
            bat(returnStatus: true, script: 'docker compose down -v')
            bat(returnStatus: true, script: 'if exist .env del /f /q .env')
            bat(returnStatus: true, script: 'docker logout')
        }
        failure {
            echo 'Проверь: docker compose в PATH у агента, creds dockerhub-creds и pg-creds, свободные порты 8000/5432.'
        }
    }
}
