pipeline {
    agent any

    options {
        timestamps()
    }

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Тег образа на Docker Hub')
    }

    environment {
        DOCKERHUB_USER = "${env.DOCKERHUB_USER ?: 'YOUR_DOCKERHUB_LOGIN'}"
        IMAGE = "${DOCKERHUB_USER}/devops3-api"
        SCENARIO_BASE_URL = "http://127.0.0.1:8000"
        POSTGRES_DB = "devops"
    }

    stages {
        stage('checkout_repo') {
            steps {
                checkout scm
            }
        }

        stage('cleanup_before') {
            steps {
                bat(returnStatus: true, script: 'docker compose --env-file secrets.env down -v')
                bat(returnStatus: true, script: 'docker rm -f devops3-vault devops3-db devops3-api')
            }
        }

        stage('docker_login_pull') {
            steps {
                bat 'docker --version'
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'DH_USER',
                        passwordVariable: 'DH_PASS'
                    )
                ]) {
                    bat 'echo %DH_PASS% | docker login -u %DH_USER% --password-stdin'
                }
                bat "docker pull ${IMAGE}:${params.IMAGE_TAG}"
                bat "docker tag ${IMAGE}:${params.IMAGE_TAG} devops3-api:latest"
            }
        }

        stage('compose_up') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'pg-creds',
                        usernameVariable: 'POSTGRES_USER',
                        passwordVariable: 'POSTGRES_PASSWORD'
                    ),
                    usernamePassword(
                        credentialsId: 'vault-token-creds',
                        usernameVariable: 'VAULT_TOKEN_USER_UNUSED',
                        passwordVariable: 'VAULT_TOKEN'
                    )
                ]) {
                    bat '''
                        (echo VAULT_TOKEN=%VAULT_TOKEN%& echo POSTGRES_DB=%POSTGRES_DB%& echo POSTGRES_USER=%POSTGRES_USER%& echo POSTGRES_PASSWORD=%POSTGRES_PASSWORD%) > secrets.env
                        docker compose --env-file secrets.env down -v
                        docker compose --env-file secrets.env up -d
                    '''
                    bat 'ping -n 31 127.0.0.1 > nul'
                }
            }
        }

        stage('vault_check') {
            steps {
                bat 'docker exec devops3-vault vault kv get -mount=secret postgres'
            }
        }

        stage('seed_db') {
            steps {
                script {
                    def rc = bat(returnStatus: true, script: 'docker compose --env-file secrets.env exec -T api python scripts/seed_db.py')
                    if (rc != 0) {
                        echo "seed_db skipped (rc=${rc}) -- data/raw/data.csv нет в образе либо не подтянут DVC"
                    }
                }
            }
        }

        stage('functional_scenarios') {
            steps {
                bat 'set SCENARIO_BASE_URL=http://127.0.0.1:8000 && python scripts/run_scenarios.py'
            }
        }
    }

    post {
        always {
            bat(returnStatus: true, script: 'docker compose --env-file secrets.env logs --no-color > compose-logs.txt 2>&1')
            archiveArtifacts artifacts: 'compose-logs.txt', allowEmptyArchive: true
            bat(returnStatus: true, script: 'docker compose --env-file secrets.env down -v')
            bat(returnStatus: true, script: 'if exist secrets.env del /f /q secrets.env')
            bat(returnStatus: true, script: 'docker logout')
        }
        failure {
            echo 'Проверь: docker compose в PATH у агента, creds dockerhub-creds, pg-creds, vault-token-creds, свободные порты 8000/5432/8200.'
        }
    }
}
