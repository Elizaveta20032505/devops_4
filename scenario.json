{
  "version": 2,
  "description": "Сценарии проверки поднятого API. SCENARIO_BASE_URL — если порт другой.",
  "default_base_url": "http://127.0.0.1:8000",
  "steps": [
    {
      "id": "health",
      "method": "GET",
      "path": "/health",
      "expect_status": 200
    },
    {
      "id": "openapi",
      "method": "GET",
      "path": "/openapi.json",
      "expect_status": 200
    },
    {
      "id": "predict_zeros",
      "method": "POST",
      "path": "/predict",
      "body_template": "zeros_from_feature_names",
      "expect_status": 200,
      "comment": "Нужна модель в образе; дальше проверка Kafka."
    },
    {
      "id": "kafka_last",
      "method": "GET",
      "path": "/kafka/last?timeout_sec=30&drain=1",
      "expect_status": 200,
      "expect_json_keys": ["label", "malignant_probability"],
      "comment": "Работает если Kafka включена и до этого был успешный POST /predict."
    },
    {
      "id": "predictions_list",
      "method": "GET",
      "path": "/predictions?limit=5",
      "expect_status_in": [200, 503],
      "comment": "200 если БД поднята и записан хотя бы один предикт; 503 если БД выключена."
    }
  ]
}
